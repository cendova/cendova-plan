{
  "name": "cendova-plan",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:open": "vite --open",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "npm run typecheck && npm run test && npm run build",
    "shot": "node scripts/screenshot.mjs"
  },
  "dependencies": {
    "@cornerstonejs/core": "^5.6.9",
    "@cornerstonejs/dicom-image-loader": "^5.6.9",
    "@cornerstonejs/tools": "^5.6.9",
    "dicom-parser": "^1.8.21",
    "fflate": "^0.8.3",
    "html2canvas-pro": "^2.3.0",
    "jspdf": "^4.2.1",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@napi-rs/canvas": "^1.0.2",
    "@tailwindcss/vite": "^4.3.3",
    "@types/node": "^22.20.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "dxf-parser": "^1.1.2",
    "marked": "^18.0.7",
    "pdfjs-dist": "^6.1.200",
    "playwright-core": "^1.61.1",
